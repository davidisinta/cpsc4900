<?xml version="1.0"?>
<robot name="cube">

  <link name="cubeLink">

    <!-- Physical properties -->
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>

      <!-- inertia tensor for unit cube -->
      <inertia
        ixx="0.166"
        iyy="0.166"
        izz="0.166"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <!-- Collision shape -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="1 1 1"/>
      </geometry>
    </collision>

    <!-- Optional visual (NO mesh dependency) -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="1 1 1"/>
      </geometry>
    </visual>

  </link>

</robot>